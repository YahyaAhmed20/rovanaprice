document.addEventListener(


"input",

async function(e){

    if(

        !e.target.classList.contains(
            "item-input"
        )

    ){

        return
    }

    const input = e.target

    const row =
        input.closest(".item-row")

    const itemId =
        row.dataset.itemId

    const field =
        input.dataset.field

    const value =
