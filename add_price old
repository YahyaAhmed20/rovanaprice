<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>عروض الأسعار — روفانا تريد</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Cairo', sans-serif;
  background: #e0dbd6;
  font-size: 13px;
  color: #1e2d3d;
}

/* ── TOOLBAR ─────────────────────────────── */
.toolbar {
  position: sticky; top: 0; z-index: 999;
  background: #1a1a1a;
  padding: 9px 20px;
  display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
  box-shadow: 0 2px 10px rgba(0,0,0,.4);
}
.tb-title { color:#fff; font-weight:900; font-size:13px; margin-left:auto; }
.tb-title span { color:#E8510A; }
.tb-serial { background:rgba(255,255,255,.12); border:1px solid rgba(255,255,255,.2); border-radius:5px; padding:4px 10px; color:#fff; font-size:11px; }
.tb-serial b { color:#E8510A; font-size:13px; }
.btn { display:inline-flex; align-items:center; gap:5px; padding:6px 14px; border-radius:5px; border:none; cursor:pointer; font-family:'Cairo',sans-serif; font-size:11px; font-weight:700; white-space:nowrap; transition:opacity .15s; }
.btn:hover { opacity:.85; }
.btn-o { background:#E8510A; color:#fff; }
.btn-g { background:#2e7d5e; color:#fff; }
.btn-d { background:#333; color:#fff; }
.btn-l { background:rgba(255,255,255,.15); color:#fff; border:1px solid rgba(255,255,255,.25); }

/* ── PAGE ─────────────────────────────────── */
.page {
  width: 210mm;
  background: #fff;
  margin: 18px auto 40px;
  box-shadow: 0 4px 32px rgba(0,0,0,.18);
}

/* ── HEADER ───────────────────────────────── */
.hd-top { background:#1a1a1a; height:5px; }
.hd-acc { background:#E8510A; height:4px; }
.hd-body {
  background:#1a1a1a; color:#fff;
  padding:14px 22px;
  display:flex; justify-content:space-between; align-items:center; gap:12px;
}
.hd-left { display:flex; align-items:center; gap:14px; flex:1; }
.hd-logo { height:56px; width:auto; object-fit:contain; flex-shrink:0; }
.hd-sep { width:2px; height:50px; background:#E8510A; flex-shrink:0; }
.hd-info { display:flex; flex-direction:column; gap:3px; }
.hd-tag { font-size:10px; color:rgba(255,255,255,.6); letter-spacing:.5px; }
.hd-contacts { font-size:9.5px; color:rgba(255,255,255,.7); line-height:2; }
.hd-badge {
  background:#E8510A; border-radius:6px;
  padding:9px 15px; text-align:center; min-width:120px; flex-shrink:0;
}
.hd-badge small { display:block; font-size:9px; letter-spacing:1.5px; color:rgba(255,255,255,.8); margin-bottom:2px; }
.hd-badge .snum { font-size:15px; font-weight:900; }
.hd-badge .sdate { display:block; font-size:9.5px; color:rgba(255,255,255,.8); margin-top:2px; }

/* ── META BAR ─────────────────────────────── */
.meta {
  background:#f4f7fb; border-bottom:1px solid #d0dbe8;
  padding:8px 22px; display:flex; gap:14px; flex-wrap:wrap; align-items:center;
}
.mf { display:flex; align-items:center; gap:5px; }
.mf label { font-size:9px; text-transform:uppercase; letter-spacing:1px; color:#6b7f93; font-weight:700; white-space:nowrap; }
.mf input {
  border:1px solid #d0dbe8; border-radius:4px; padding:3px 7px;
  font-family:'Cairo',sans-serif; font-size:11px; font-weight:700; color:#1a1a1a;
  background:#fff; outline:none;
}
.mf input:focus { border-color:#E8510A; }

/* ── BODY ─────────────────────────────────── */
.pg-body { padding:16px 22px; }

/* ── PARTIES ──────────────────────────────── */
.parties { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:12px; }
.pc { border:1px solid #d0dbe8; border-radius:6px; overflow:hidden; }
.pc-head { background:#1a1a1a; color:#fff; padding:5px 11px; font-size:10px; font-weight:700; }
.pc-body { padding:8px 11px; background:#f9fbfd; }
.pc-body input {
  display:block; width:100%; border:none; background:transparent;
  font-family:'Cairo',sans-serif; font-size:13px; font-weight:800; color:#1a1a1a;
  outline:none; margin-bottom:4px;
}

/* ── AUTO-EXPAND TEXTAREA ─────────────────── */
/* The key: NO height, just min-height, overflow visible on parents */
textarea {
  display:block;
  width:100%;
  border:none;
  background:transparent;
  font-family:'Cairo',sans-serif;
  font-size:12px;
  color:#1e2d3d;
  line-height:1.8;
  resize:none;
  outline:none;
  overflow:hidden;
  min-height:28px;
  padding:0;
}

.pc-body textarea { font-size:11px; color:#6b7f93; min-height:32px; }
.proj-box textarea { font-size:12px; min-height:48px; }
.note-body textarea { font-size:11px; min-height:60px; line-height:1.9; }

/* ── PROJECT DESC ─────────────────────────── */
.proj-box {
  background:linear-gradient(135deg,#fdf3ee,#fde8dc);
  border:1px solid #f5c4a8; border-right:4px solid #E8510A;
  border-radius:6px; padding:10px 13px; margin-bottom:12px;
}

/* ── SECTION TITLE ────────────────────────── */
.sec-title { display:flex; align-items:center; gap:8px; margin:12px 0 8px; }
.sec-title hr { flex:1; border:none; border-top:1px solid #d0dbe8; }
.sec-title span {
  font-size:10px; font-weight:800; padding:2px 10px;
  background:#E8510A; color:#fff; border-radius:20px; white-space:nowrap;
}

/* ── TABLE ────────────────────────────────── */
table.items { width:100%; border-collapse:collapse; font-size:11px; }
table.items thead tr { background:#1a1a1a; color:#fff; }
table.items thead th { padding:7px 7px; font-size:10px; font-weight:700; text-align:center; white-space:nowrap; }
table.items thead th:nth-child(2) { text-align:right; }
table.items tbody tr { border-bottom:1px solid #e8eef5; }
table.items tbody tr:nth-child(even) { background:#f7fafd; }
table.items tbody tr.sec-row { background:#fff0e8; }
table.items td { padding:4px 6px; text-align:center; vertical-align:middle; }
table.items td:nth-child(2) { text-align:right; }

table.items input {
  width:100%; border:1px solid transparent; border-radius:3px;
  padding:3px 5px; font-family:'Cairo',sans-serif; font-size:11px;
  color:#1e2d3d; background:transparent; outline:none; text-align:inherit;
  transition:border .1s;
}
table.items input:focus { border-color:#E8510A; background:#fff8f5; }
table.items input[type=number] { text-align:center; direction:ltr; }

.sec-row input {
  font-weight:800; color:#E8510A; font-size:11px;
  border:none !important; background:transparent !important;
}

select.unit-sel {
  width:100%; border:1px solid transparent; border-radius:3px;
  padding:3px 2px; font-family:'Cairo',sans-serif; font-size:11px;
  color:#1e2d3d; background:transparent; outline:none; cursor:pointer;
}
select.unit-sel:focus { border-color:#E8510A; background:#fff8f5; }

.badge {
  background:#E8510A; color:#fff; border-radius:50%;
  width:19px; height:19px; display:inline-flex;
  align-items:center; justify-content:center; font-size:9px; font-weight:700;
}
.total-cell { font-weight:700; color:#2e7d5e; direction:ltr; }
.del-btn {
  background:none; border:none; color:#ccc; cursor:pointer;
  font-size:13px; padding:2px 4px; border-radius:3px; transition:all .15s;
}
.del-btn:hover { color:#c0392b; background:#fef0f0; }

/* ── ADD BUTTONS ──────────────────────────── */
.add-area { display:flex; gap:7px; margin:5px 0 2px; }
.add-btn {
  border:1px dashed #d0dbe8; background:none; border-radius:4px;
  padding:3px 11px; font-family:'Cairo',sans-serif; font-size:11px;
  color:#6b7f93; cursor:pointer; transition:all .15s;
}
.add-btn:hover { border-color:#E8510A; color:#E8510A; background:#fff5f0; }

/* ── TOTALS ───────────────────────────────── */
.totals-wrap { margin-top:12px; }
.totals-tbl { width:300px; border-collapse:collapse; }
.totals-tbl td { padding:5px 10px; border-bottom:1px solid #d0dbe8; }
.tl { color:#6b7f93; font-size:11px; font-weight:600; }
.tv { text-align:left; font-weight:700; font-size:12px; direction:ltr; }
.grand td { background:#1a1a1a; font-weight:900; padding:8px 10px; }
.grand .tl { color:rgba(255,255,255,.8); font-size:12px; }
.grand .tv { color:#E8510A !important; font-size:14px; }
.vat-row { display:flex; align-items:center; gap:4px; }
.vat-row input {
  width:44px; border:1px solid #d0dbe8; border-radius:3px;
  padding:2px 4px; font-family:'Cairo',sans-serif; font-size:11px;
  text-align:center; direction:ltr; outline:none;
}

/* ── VALIDITY BANNER ──────────────────────── */
.val-banner {
  background:#fff5f0; border:1px solid #f5c4a8; border-radius:6px;
  padding:7px 12px; font-size:11px; color:#8a3300; font-weight:600;
  margin-top:10px; display:flex; align-items:flex-start; gap:6px;
}
.val-banner [contenteditable] {
  flex:1; outline:none; min-height:18px; line-height:1.8;
}

/* ── NOTES ────────────────────────────────── */
.notes { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-top:12px; }
.note-box { border:1px solid #d0dbe8; border-radius:6px; overflow:hidden; }
.note-head { background:#f4f7fb; border-bottom:1px solid #d0dbe8; padding:4px 10px; font-size:10px; font-weight:800; color:#1a1a1a; }
.note-body { padding:8px 10px; }

/* ── SIGNATURES ───────────────────────────── */
.sigs { display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-top:16px; }
.sig-box { border:1px dashed #d0dbe8; border-radius:6px; padding:10px 14px; text-align:center; }
.sig-lbl { font-size:9px; font-weight:700; color:#6b7f93; text-transform:uppercase; letter-spacing:1px; margin-bottom:4px; }
.sig-box input {
  width:100%; border:none; border-top:1px solid #d0dbe8; background:transparent;
  font-family:'Cairo',sans-serif; font-size:12px; font-weight:800; color:#1a1a1a;
  text-align:center; outline:none; padding-top:5px; margin-top:18px; display:block;
}

/* ── FOOTER ───────────────────────────────── */
.pg-footer {
  background:#1a1a1a; color:rgba(255,255,255,.65);
  padding:7px 22px; font-size:9px;
  display:flex; justify-content:space-between; align-items:center;
  margin-top:18px; letter-spacing:.3px;
}
.pg-footer strong { color:#fff; }
.pg-footer .fa { color:#E8510A; font-weight:700; }

/* ── HINT ─────────────────────────────────── */
.hint {
  position:fixed; bottom:18px; left:18px;
  background:#1a1a1a; color:rgba(255,255,255,.75);
  padding:7px 13px; border-radius:20px; font-size:10px;
  box-shadow:0 2px 10px rgba(0,0,0,.2); pointer-events:none; z-index:99;
}
.hint b { color:#E8510A; }

/* ── MERGE BUTTON ─────────────────────────── */
.mrg-btn {
  background: none; border: none; color: #aaa; cursor: pointer;
  font-size: 13px; padding: 2px 4px; border-radius: 3px;
  transition: all .15s; margin-right: 2px;
}
.mrg-btn:hover { color: #E8510A; background: #fff5f0; }
tr.merged td:nth-child(2) { font-weight: 700; }

/* ── PRINT ────────────────────────────────── */
@media print {
  .toolbar,.add-area,.del-btn,.add-btn,.hint { display:none !important; }
  body { background:#fff; }
  .page { margin:0; box-shadow:none; width:100%; }
  * { -webkit-print-color-adjust:exact; print-color-adjust:exact; }
  textarea { overflow:visible !important; height:auto !important; }
  @page { margin:0; size:A4; }
}

.qty-input{


width:90px !important;

min-width:90px;

text-align:center;

font-size:14px;

padding:7px;


}

.unit-input{


width:90px !important;

min-width:90px;

text-align:center;

font-size:14px;

padding:7px;


}

.price-input{


width:130px !important;

min-width:130px;

text-align:center;

font-size:14px;

padding:7px;




.item-input{


border:1px solid #ddd;

border-radius:6px;

padding:8px;

width:100%;


}

}

</style>
</head>
<body>
<div class="toolbar">

    <div class="tb-title">
        🗂 <span>عروض الأسعار</span> — روفانا تريد
    </div>

    <div class="tb-serial">
        رقم العرض:
        <b id="snDisplay">{{ quotation.quote_number }}</b>
    </div>

    <button class="btn btn-d" id="newQuoteBtn">
        ＋ جديد
    </button>

    <button class="btn btn-o" id="saveQuoteBtn">
        💾 حفظ
    </button>

    <button class="btn btn-g" onclick="window.print()">
        🖨 طباعة / PDF
    </button>

</div>

<div class="page">
  <div class="hd-top"></div>
  <div class="hd-acc"></div>
  <div class="hd-body">
    <div class="hd-left">
      <img class="hd-logo" src="data:image/jpeg;base64," alt="Rovana">
      <div class="hd-sep"></div>
      <div class="hd-info">
        <div class="hd-tag">تصنيع وتجارة المعادن · صفائح كابل تراي · هياكل فولاذية</div>
        <div class="hd-contacts">
          🌐 www.rovanatrade.com &nbsp;|&nbsp; ✉ info@rovanatrade.com &nbsp;|&nbsp; ✉ sara.galal@rovanatrade.com<br>
          📞 01061166987 &nbsp;|&nbsp; 📍 المعتمدية - المهندسين - محافظة الجيزة
        </div>
      </div>
    </div>
    <div class="hd-badge">
      <div class="hd-badge">


<small>
    عرض سعر رقم
</small>

<div
    class="snum"
    id="snPage"
>

    {{ quotation.quote_number }}

</div>

<span
    class="sdate"
    id="snDate"
>

    {{ quotation.created_at|date:"Y-m-d h:i A" }}

</span>


</div>

    </div>
  </div>
<div class="meta">

    <div class="mf">
        <label>رقم المرجع</label>

        <input
            id="metaRef"
            data-field="reference_number"
            value="{{ quotation.reference_number|default:'' }}"
            placeholder="SA-Plant-Mech-004"
            style="width:130px"
        >
    </div>

    <div class="mf">
        <label>الكود / Tag</label>

        <input
            id="metaTag"
            data-field="tag"
            value="{{ quotation.tag|default:'' }}"
            placeholder="Tag No."
            style="width:90px"
        >
    </div>

    <div class="mf">
        <label>المادة</label>

        <input
            id="metaMat"
            data-field="material"
            value="{{ quotation.material|default:'' }}"
            placeholder="SS304 / Carbon Steel"
            style="width:130px"
        >
    </div>

    <div class="mf">
        <label>تليفون العميل</label>

        <input
            id="metaPhone"
            data-field="customer_phone"
            value="{{ quotation.customer_phone|default:'' }}"
            placeholder="01xxxxxxxxx"
            style="width:110px"
        >
    </div>

    <div class="mf">
        <label>إيميل العميل</label>

        <input
            id="metaEmail"
            data-field="customer_email"
            value="{{ quotation.customer_email|default:'' }}"
            placeholder="email@company.com"
            style="width:150px"
        >
    </div>

    <div class="mf">
        <label>صلاحية العرض</label>

        <input
            id="metaValidity"
            data-field="validity"
            value="{{ quotation.validity }}"
            style="width:75px"
        >
    </div>

    <div class="mf">
        <label>التاريخ والوقت</label>

        <input
            id="metaDatetime"
            readonly
            value="{{ quotation.created_at|date:'Y-m-d H:i' }}"
            style="
                width:155px;
                background:#f0f4f8;
                color:#1a1a1a;
                cursor:default;
                font-size:10.5px;
            "
        >
    </div>

</div>



<div class="pg-body">

    <div class="parties">

        <div class="pc">

            <div class="pc-head">
                ⬤ مقدّم العرض
            </div>

            <div class="pc-body">

                <input
                    type="text"
                    data-field="submitted_by_name"
                    value="{{ quotation.submitted_by_name }}"
                >

                <textarea
                    data-field="submitted_by_details"
                    placeholder="التخصص والعنوان"
                >{{ quotation.submitted_by_details|default:'' }}</textarea>

            </div>

        </div>



        <div class="pc">

            <div class="pc-head">
                ⬤ مقدَّم إلى
            </div>

            <div class="pc-body">

                <input
                    id="toName"
                    type="text"
                    data-field="submitted_to_name"
                    value="{{ quotation.submitted_to_name|default:'' }}"
                    placeholder="اسم العميل / الشركة"
                >

                <textarea
                    id="toDetail"
                    data-field="submitted_to_details"
                    placeholder="المشروع — الموقع — كود المعدة"
                >{{ quotation.submitted_to_details|default:'' }}</textarea>

            </div>

        </div>

    </div>



    <div class="proj-box">

        <textarea
            id="projDesc"
            data-field="project_description"
            placeholder="وصف المشروع وموضوع عرض السعر..."
        >{{ quotation.project_description|default:'' }}</textarea>

    </div>

</div>
<div class="sec-title">
    <hr>
    <span>
        بنود نطاق العمل والتسعير
    </span>
    <hr>
</div>



<table class="items">

    <thead>

        <tr>

            <th style="width:22px">#</th>

            <th style="width:42%">
                البند / الوصف
            </th>

            <th style="width:7%">
                الكمية
            </th>

            <th style="width:9%">
                الوحدة
            </th>

            <th style="width:13%">
                سعر الوحدة (ج.م)
            </th>

            <th style="width:13%">
                الإجمالي (ج.م)
            </th>

            <th style="width:20px"></th>

        </tr>

    </thead>

   <tbody id="tbody">

{% for section in quotation.sections.all %}

<tr class="section-row">

    <td colspan="7">

        <div class="section-head">

            <input
                type="text"

                class="section-title"

                value="{{ section.title }}"

                data-section-id="{{ section.id }}"
            >

            <div class="section-actions">

                <button
                    class="mini-btn"

                    onclick="addItem({{ section.id }})"
                >

                    ＋ بند

                </button>

                <button
                    class="mini-btn del"

                    onclick="deleteSection({{ section.id }})"
                >

                    ✕

                </button>

            </div>

        </div>

    </td>

</tr>



{% for item in section.items.all %}

<tr
    class="item-row"
    data-item-id="{{ item.id }}"
>

    <td></td>

    <td>

        <textarea
            class="item-input"
            data-field="description"
        >{{ item.description|default:'' }}</textarea>

    </td>

    <td>

        <input
            type="number"

            class="item-input qty-input"

            data-field="quantity"

            value="{{ item.quantity }}"
        >

    </td>

    <td>

       <select
class="item-input unit-input"
data-field="unit"

>


{% for unit in units %}

    <option

        value="{{ unit.name }}"

        {% if item.unit == unit.name %}
            selected
        {% endif %}

    >

        {{ unit.name }}

    </option>

{% endfor %}


</select>

    </td>

    <td>

        <input
            type="number"

            class="item-input qty-input"

            data-field="unit_price"

            value="{{ item.unit_price }}"
        >

    </td>

    <td class="line-total">

        {{ item.total_price|floatformat:2 }}

    </td>

    <td>

        <button
            class="del-btn"

            onclick="deleteItem({{ item.id }})"
        >

            ✕

        </button>

    </td>

</tr>

{% endfor %}

{% endfor %}

</tbody>

</table>



<div class="add-area">

    <button
        class="add-btn"
        onclick="addSection()"
    >

        ＋ إضافة قسم

    </button>


</div>



<div class="totals-wrap">

    <table class="totals-tbl">

        <tr>

            <td class="tl">
                الإجمالي قبل الضريبة
            </td>

            <td class="tv" id="tSub">
                0 EGP
            </td>

        </tr>

        <tr>

            <td class="tl">

                <div class="vat-row">

                    ضريبة القيمة المضافة

                    <input
                        id="vatRate"
                        type="number"
                        value="{{ quotation.vat_rate }}"
                        min="0"
                        max="100"
                    >

                    %

                </div>

            </td>

            <td class="tv" id="tVat">
                0 EGP
            </td>

        </tr>

        <tr class="grand">

            <td class="tl">
                الإجمالي الكلي شامل الضريبة
            </td>

            <td class="tv" id="tGrand">
                0 EGP
            </td>

        </tr>

    </table>

</div>



<div class="val-banner">

    ⚠

    <div
        id="warningNote"
        contenteditable="true"
    >

        {{ quotation.warning_note }}

    </div>

</div>
<div class="sec-title" style="margin-top:14px">

    <hr>

    <span>
        الشروط والأحكام
    </span>

    <hr>

</div>



<div class="notes">



    <div class="note-box">

        <div class="note-head">
            📋 شروط الدفع
        </div>

        <div class="note-body">

