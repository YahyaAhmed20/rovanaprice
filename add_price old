function recalcTotals(){

    let subtotal = 0

    document
    .querySelectorAll(".line-total")
    .forEach(el => {

        subtotal += parseFloat(
            el.innerText
        ) || 0
    })

    const vatRate =
        parseFloat(
            document.getElementById("vatRate").value
        ) || 0

    const vat =
        subtotal * vatRate / 100

    const grand =
        subtotal + vat

    document.getElementById("tSub")
    .innerHTML =
        subtotal.toFixed(2) + " EGP"

    document.getElementById("tVat")
    .innerHTML =
        vat.toFixed(2) + " EGP"

    document.getElementById("tGrand")
    .innerHTML =
        grand.toFixed(2) + " EGP"
}



document
.getElementById("vatRate")
.addEventListener("input", recalcTotals)


recalcTotals()



