                "X-CSRFToken":
                    csrftoken

            },

            body: JSON.stringify({

                field: field,

                value: value

            })

        }

    )


    const data =
        await response.json()


    row.querySelector(
        ".line-total"
    ).innerHTML =

        parseFloat(
            data.total_price
        ).toFixed(2)


    recalcTotals()

}


)




